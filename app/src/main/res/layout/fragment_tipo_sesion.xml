<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/verde_oscuro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_logo"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="12dp"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GESTION TRAZA"
            android:textColor="@color/blanco"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Cómo vas a trabajar hoy?"
            android:textColor="#bbffffff"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="40dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConsignatario"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:text="CONSIGNATARIO"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            style="@style/BtnGray"
            app:cornerRadius="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnProductor"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:text="PRODUCTOR"
            android:textSize="18sp"
            android:textStyle="bold"
            style="@style/BtnGray"
            app:cornerRadius="16dp"/>

        <TextView
            android:id="@+id/tvSesionNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#66ffffff"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="28dp"/>

    </LinearLayout>
</ScrollView>
